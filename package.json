{
  "name": "nexus-breach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "generate:templates": "tsx scripts/generateTemplates.ts",
    "generate:assets": "tsx scripts/generateAssets.ts"
  },
  "dependencies": {
    "@pixi/react": "^7.1.2",
    "howler": "^2.2.4",
    "immer": "^10.1.1",
    "pixi.js": "^7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "c8": "^10.1.3",
    "dotenv": "^17.2.4",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "form-data": "^4.0.5",
    "happy-dom": "^20.5.3",
    "jsdom": "^28.0.0",
    "openai": "^6.19.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.11",
    "vitest": "^4.0.18"
  }
}
