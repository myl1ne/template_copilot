// Firestore Security Rules for Ghostless Shell
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read access for portfolio content
    match /resume/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'owner_uid';
    }
    
    match /notes/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'owner_uid';
    }
    
    match /research/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'owner_uid';
    }
    
    match /experiments/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'owner_uid';
    }
    
    // Chat sessions - visitors can create but not read others'
    match /chat_sessions/{sessionId} {
      allow create: if true;
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.user_id || 
         request.auth.uid == 'owner_uid');
    }
    
    // Analytics and tracking (write-only for visitors, read for owner)
    match /analytics/{document} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.uid == 'owner_uid';
    }
    
    // Site configuration (owner only)
    match /config/{document} {
      allow read, write: if request.auth != null && request.auth.uid == 'owner_uid';
    }
  }
}